<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_card_round"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true">

    <!-- ROUTINE NAME -->
    <TextView
        android:id="@+id/tvRoutineName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Routine Name"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#EAF6FA"/>

    <!-- ROUTINE INFO -->
    <TextView
        android:id="@+id/tvRoutineInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3 times/week • Home / Gym"
        android:textSize="14sp"
        android:textColor="#B8D6DE"
        android:layout_marginTop="4dp"/>

    <!-- ACTION BUTTONS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="12dp"
        android:clickable="false"
        android:focusable="false">

        <!-- ✔ MARK DONE -->
        <ImageButton
            android:id="@+id/btnDone"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/checkbox_on_background"
            android:background="@android:color/transparent"
            android:importantForAccessibility="yes"/>

        <!-- ✏ EDIT -->
        <ImageButton
            android:id="@+id/btnEdit"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_edit"
            android:background="@android:color/transparent"
            android:importantForAccessibility="yes"/>

        <!-- ➤ DELEGATE (SMS) -->
        <ImageButton
            android:id="@+id/btnDelegate"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="@android:color/transparent"
            android:importantForAccessibility="yes"/>

        <!-- 🗑 DELETE -->
        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="@android:color/transparent"
            android:importantForAccessibility="yes"/>
    </LinearLayout>

</LinearLayout>
