<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_neon_gradient">

    <!-- Greeting -->
    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hello,"
        android:textSize="16sp"
        android:textColor="#9FB3C8"
        android:fontFamily="@font/montserrat_medium"
        android:layout_marginTop="56dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvUserName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="User 👋"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:fontFamily="@font/montserrat_bold"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvGreeting"
        app:layout_constraintStart_toStartOf="@id/tvGreeting"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Lets build a healthier you.\nOne step at a time."
        android:textSize="14sp"
        android:textColor="#A7C0CD"
        android:fontFamily="@font/montserrat_regular"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvUserName"
        app:layout_constraintStart_toStartOf="@id/tvUserName"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Distance Tracker -->
    <FrameLayout
        android:id="@+id/distanceContainer"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/distanceProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:max="100"
            android:progress="0"
            android:indeterminate="false"
            android:progressDrawable="@drawable/circular_progress"
            android:background="@drawable/circular_background"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00 km"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/montserrat_bold"/>

            <TextView
                android:id="@+id/tvGoal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Weekly Goal: 7 KM"
                android:textSize="13sp"
                android:textColor="#9FB3C8"
                android:fontFamily="@font/montserrat_regular"
                android:layout_marginTop="6dp"/>
        </LinearLayout>
    </FrameLayout>

    <!-- Weekly Summary Card -->
    <LinearLayout
        android:id="@+id/weeklySummaryCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/summary_card_bg"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/distanceContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This Week"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvWeeklyTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total: 0.00 km"
            android:textColor="#C8DCE6"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvWeeklyAverage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Avg/day: 0.00 km"
            android:textColor="#C8DCE6"
            android:textSize="14sp"
            android:layout_marginTop="6dp"/>

        <TextView
            android:id="@+id/tvWeeklyGoal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Goal: 0% completed"
            android:textColor="#C8DCE6"
            android:textSize="14sp"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

    <!-- Start Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStart"
        android:layout_width="0dp"
        android:layout_height="56dp"

        android:text="Start My Fitness Journey"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#0B1E3B"

        app:backgroundTint="#F4FBFF"
        app:cornerRadius="28dp"
        app:strokeWidth="1dp"
        app:strokeColor="#B8D6DE"

        android:elevation="8dp"

        android:layout_marginTop="24dp"
        android:layout_marginBottom="56dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"

        app:layout_constraintTop_toBottomOf="@id/weeklySummaryCard"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>



</androidx.constraintlayout.widget.ConstraintLayout>
